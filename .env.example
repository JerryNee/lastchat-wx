# 你的 Claude Skill 目录（包含 SKILL.md / persona.md / memories.md）。
# 默认 ./skill。建议用 https://github.com/perkfly/ex-skill 蒸出来的 skill 放这里。
SKILL_DIR=./skill

# persona 怎么称呼你（人类）。默认 "对方"。强烈建议改成 persona 笔记里实际用的称呼。
# 例如对方在 persona.md 里叫你「小K」「宝」，就 BOT_CONTACT_NAME=小K
BOT_CONTACT_NAME=对方

# claude CLI 模型 alias。默认 claude-sonnet-4-6。
BOT_MODEL=claude-sonnet-4-6

# 历史回放窗口（轮）。默认 80。窗口外的事实由 rolling facts 兜底。
BOT_HISTORY_TURNS=80

# 摘要器每轮看的历史长度。默认 40。
BOT_FACTS_TURNS=40

# 单次 claude 子进程超时（毫秒）。默认 180_000。
BOT_REPLY_TIMEOUT_MS=180000

# 用户连发合批的 debounce 抖动（毫秒）。
BOT_DEBOUNCE_MIN_MS=2000
BOT_DEBOUNCE_MAX_MS=6000

# 发送相邻多句的最小/最大间隔（毫秒）。模拟真人打字节奏，也防风控。
BOT_SEND_GAP_MIN_MS=1200
BOT_SEND_GAP_MAX_MS=2500

# 主动 nudge 相关。
BOT_NUDGE_THRESHOLD_MS=21600000
BOT_NUDGE_CHECK_INTERVAL_MS=60000
BOT_NUDGE_ENABLED=true
